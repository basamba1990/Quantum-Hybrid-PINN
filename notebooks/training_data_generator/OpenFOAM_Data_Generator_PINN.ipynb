      "cell_type": "markdown",
      "source": [
        "## 3.1. Classe `OpenFOAMUtils` (Adaptée pour Colab)\n",
        "\n",
        "Nous allons inclure une version simplifiée de la classe `OpenFOAMUtils` pour gérer la création de cas, l'exécution simulée de `blockMesh` et l'extraction de données."
      ],
      "metadata": {
        "id": "openfoam_utils_md"
      }
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "openfoam_utils_class"
      },
      "outputs": [],
      "source": [
        "class OpenFOAMUtils:\n",
        "    def __init__(self, case_path):\n",
        "        self.case_path = Path(case_path)\n",
        "\n",
        "    def run_subprocess(self, command, capture_output=True, text=True):\n",
        "        # Simule l'exécution d'une commande shell. En environnement réel, utiliser subprocess.run\n",
        "        print(f\"Simulating command: {" ".join(command)}\")\n",
        "        return \"Simulated output\"\n",
        "\n",
        "    def generate_mesh(self, mesh_utility=\"blockMesh\"):\n",
        "        poly_mesh = self.case_path / \"constant\" / \"polyMesh\"\n",
        "        if poly_mesh.exists():\n",
        "            return \"ℹ️ Le maillage existe déjà, aucune génération effectuée.\"\n",
        "        \n",
        "        # Créer un répertoire polyMesh simulé\n",
        "        poly_mesh.mkdir(parents=True, exist_ok=True)\n",
        "        (poly_mesh / \"points\").touch() # Fichier bidon pour simuler l'existence\n",
        "        \n",
        "        # Simuler l'exécution de blockMesh\n",
        "        cmd = [mesh_utility, \"-case\", str(self.case_path)]\n",
        "        log = self.run_subprocess(cmd)\n",
        "        return f\"✅ Maillage généré avec {mesh_utility}.\\n{log}\"\n",
        "\n",
        "    def run_solver(self, solver, n_processors=1):\n",
        "        print(f\"Simulating OpenFOAM solver {solver} for case {self.case_path.name}\")\n",
        "        # Simuler la création de fichiers de résultats\n",
        "        time_dir = self.case_path / str(self.case_parameters.get(\'endTime\', 100))\n",
        "        time_dir.mkdir(exist_ok=True)\n",
        "        (time_dir / \"U\").touch()\n",
        "        (time_dir / \"p\").touch()\n",
        "        return \"Simulated solver output\"\n",
        "\n",
        "    def parse_to_numpy(self, variables, time_list, save_dir=None, round_to=6):\n",
        "        if save_dir is None:\n",
        "            save_dir = self.case_path.parent / \"Assets\" / self.case_path.name\n",
        "        save_dir = Path(save_dir)\n",
        "        save_dir.mkdir(parents=True, exist_ok=True)\n",
        "\n",
        "        all_data = {var: [] for var in variables}\n",
        "        for t in time_list:\n",
        "            # Simuler la lecture de données (remplacer par Ofpp.parse_internal_field en réel)\n",
        "            for var in variables:\n",
        "                # Créer des données aléatoires pour simuler les champs\n",
        "                nx, ny, nz = self.case_parameters.get(\'nx\', 50), self.case_parameters.get(\'ny\', 10), self.case_parameters.get(\'nz\', 10)\n",
        "                if var == \"U\": # Vecteur\n",
        "                    data = np.random.rand(nx, ny, nz, 3)\n",
        "                else: # Scalaire\n",
        "                    data = np.random.rand(nx, ny, nz)\n",
        "                all_data[var].append(data)\n",
        "\n",
        "        # Sauvegarder les données simulées\n",
        "        for var in variables:\n",
        "            np.save(save_dir / f\"{var}_{self.case_path.name}.npy\", np.array(all_data[var]))\n",
        "        return save_dir\n",
        "\n",
        "print(\"Classe OpenFOAMUtils adaptée prête.\")"
      ]
    },
    {
      "cell_type": "code",
