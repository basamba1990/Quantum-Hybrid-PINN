        "    p_mean, p_std = p_data.mean(), p_data.std() + 1e-8\n",
        "    U_norm = (U_data - U_mean) / U_std\n",
        "    p_norm = (p_data - p_mean) / p_std\n",
        "\n",
        "    all_extracted_data.append({\n",
        "        \'name\': params[\'name\'],\n",
        "        \'U_norm\': U_norm,\n",
        "        \'p_norm\': p_norm,\n",
        "        \'U_mean\': U_mean, \'U_std\': U_std,\n",
        "        \'p_mean\': p_mean, \'p_std\': p_std,\n",
        "        \'params\': params\n",
        "    })\n",
        "\n",
