        "|    \\\\\\/     M anipulation  |                                                 |\\n",
        "\\\\*---------------------------------------------------------------------------*/\\n",
        "FoamFile\\n",
        "{\\n",
        "    version     2.0;\\n",
        "    format      ascii;\\n",
        "    class       dictionary;\\n",
        "    object      controlDict;\\n",
