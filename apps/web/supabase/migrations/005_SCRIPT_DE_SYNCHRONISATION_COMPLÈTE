-- 0. NETTOYAGE DES VUES (Indispensable pour modifier les tables)
DROP VIEW IF EXISTS analysis_summary CASCADE;
DROP VIEW IF EXISTS user_statistics CASCADE;
DROP VIEW IF EXISTS credibility_trends CASCADE;

-- 1. GARANTIR LA TABLE USERS
CREATE TABLE IF NOT EXISTS users (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    auth_id UUID NOT NULL UNIQUE,
    email VARCHAR(255) NOT NULL UNIQUE,
    full_name VARCHAR(255),
    avatar_url TEXT,
    role VARCHAR(50) DEFAULT 'user',
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- 2. GARANTIR LA TABLE PROJECTS
CREATE TABLE IF NOT EXISTS projects (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,
    name VARCHAR(255) NOT NULL,
    description TEXT,
    category VARCHAR(100),
    status VARCHAR(50) DEFAULT 'draft',
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- 3. SYNCHRONISATION DE LA TABLE 'analyses' (Colonne par colonne)
CREATE TABLE IF NOT EXISTS analyses (id UUID PRIMARY KEY DEFAULT gen_random_uuid());

DO $$ 
BEGIN 
    -- Ajout de project_id
    IF NOT EXISTS (SELECT 1 FROM information_schema.columns WHERE table_name='analyses' AND column_name='project_id') THEN
        ALTER TABLE analyses ADD COLUMN project_id UUID REFERENCES projects(id) ON DELETE CASCADE;
    END IF;

    -- Ajout de user_id
    IF NOT EXISTS (SELECT 1 FROM information_schema.columns WHERE table_name='analyses' AND column_name='user_id') THEN
        ALTER TABLE analyses ADD COLUMN user_id UUID REFERENCES users(id) ON DELETE CASCADE;
    END IF;

    -- Ajout de title
    IF NOT EXISTS (SELECT 1 FROM information_schema.columns WHERE table_name='analyses' AND column_name='title') THEN
        ALTER TABLE analyses ADD COLUMN title VARCHAR(255) DEFAULT 'Nouvelle Analyse';
    END IF;

    -- Ajout de status
    IF NOT EXISTS (SELECT 1 FROM information_schema.columns WHERE table_name='analyses' AND column_name='status') THEN
        ALTER TABLE analyses ADD COLUMN status VARCHAR(50) DEFAULT 'pending';
    END IF;

    -- Ajout de credibility_score
    IF NOT EXISTS (SELECT 1 FROM information_schema.columns WHERE table_name='analyses' AND column_name='credibility_score') THEN
        ALTER TABLE analyses ADD COLUMN credibility_score DECIMAL(5, 2);
    END IF;

    -- Ajout des timestamps
    IF NOT EXISTS (SELECT 1 FROM information_schema.columns WHERE table_name='analyses' AND column_name='created_at') THEN
        ALTER TABLE analyses ADD COLUMN created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW();
    END IF;
    
    IF NOT EXISTS (SELECT 1 FROM information_schema.columns WHERE table_name='analyses' AND column_name='updated_at') THEN
        ALTER TABLE analyses ADD COLUMN updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW();
    END IF;
END $$;

-- 4. RECRÉATION DE LA VUE analysis_summary (Sécurisée)
CREATE OR REPLACE VIEW analysis_summary AS
SELECT 
    id, 
    project_id, 
    user_id, 
    title, 
    status, 
    credibility_score, 
    created_at 
FROM analyses;

-- 5. RECRÉATION DE LA VUE user_statistics
CREATE OR REPLACE VIEW user_statistics AS
SELECT 
    u.id, 
    u.email, 
    COUNT(DISTINCT p.id) as project_count, 
    COUNT(DISTINCT a.id) as analysis_count
FROM users u
LEFT JOIN projects p ON u.id = p.user_id
LEFT JOIN analyses a ON u.id = a.user_id
GROUP BY u.id, u.email;

-- 6. POLITIQUES RLS (Mise à jour)
ALTER TABLE analyses ENABLE ROW LEVEL SECURITY;
DROP POLICY IF EXISTS "view_own_analyses" ON analyses;
CREATE POLICY "view_own_analyses" ON analyses FOR SELECT USING (
    EXISTS (SELECT 1 FROM users WHERE users.id = analyses.user_id AND users.auth_id = auth.uid())
);

-- FIN
SELECT 'SYNCHRONISATION ANALYSES TERMINÉE' as status;
